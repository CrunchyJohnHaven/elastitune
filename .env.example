# ElastiTune environment variables
# Copy to .env and fill in values

# Optional: LLM provider for synthetic query and persona generation
# Leave unset or set to 'disabled' to use heuristic fallback
LLM_PROVIDER=disabled
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# Optional: vector storage cost per GB per month (used for compression savings estimate)
COST_PER_GB_MONTH=0.095

# ElastiTune environment template
#
# Mode guide:
# - Search mode: requires Elasticsearch access in the UI for live runs.
# - Committee mode: requires no extra env vars unless you wire in an LLM.
# - Demo mode: runs with the bundled demo payloads and no external services.

# Shared runtime
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173
MAX_SAMPLE_DOCS=120
KEEP_THRESHOLD=0.001
METRICS_INTERVAL_SECONDS=2.0
PERSONA_BATCH_INTERVAL_SECONDS=1.5
COST_PER_GB_PER_MONTH=0.095

# Optional integrations
# Elasticsearch endpoint used by live search mode tools and future Kibana flows.
ELASTIC_URL=
ELASTIC_API_KEY=

# Optional LLM credentials for committee mode or future demo automation.
OPENAI_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=disabled

# Optional persistence override. The app currently defaults to SQLite in backend/data/.
DATABASE_URL=

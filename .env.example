# ElastiTune environment variables

# Server bind address for the FastAPI backend.
# Required for all modes.
HOST=0.0.0.0

# Backend HTTP port.
# Required for all modes.
PORT=8000

# Comma-separated list of allowed browser origins for local/dev access.
# Required for local development and the demo UI.
CORS_ORIGINS=http://localhost:5173

# Elasticsearch connection defaults.
# Required for Search mode when you connect to a live cluster.
# Some teams also refer to these as ELASTIC_URL / ELASTIC_API_KEY.
ES_URL=
ES_API_KEY=

# Optional compatibility aliases for external tooling or deployment scripts.
# Keep these in sync with ES_URL / ES_API_KEY if you use them.
ELASTIC_URL=
ELASTIC_API_KEY=

# OpenAI-compatible credentials used by committee mode when you enable LLM support.
# Required only for Committee mode if you want model-backed personas or evaluations.
OPENAI_API_KEY=
DEFAULT_LLM_PROVIDER=disabled
DEFAULT_LLM_BASE_URL=
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_LLM_API_KEY=

# Optional external persistence / deployment hooks.
# Not required for the current demo, but useful if you wire the app to an external database.
DATABASE_URL=

# Demo estimate used in vector compression savings projections.
# Required for Search mode and the demo report.
COST_PER_GB_PER_MONTH=0.095

# Default live-run persona count when the client does not override it.
# Required for Search mode.
DEFAULT_PERSONA_COUNT=24

# Max docs to sample during index analysis.
# Required for Search mode.
MAX_SAMPLE_DOCS=120

# Minimum absolute score gain required to keep an experiment.
# Required for Search mode.
KEEP_THRESHOLD=0.001

# Metrics websocket tick cadence in seconds.
# Required for the live demo UI.
METRICS_INTERVAL_SECONDS=2.0

# Persona activity batch cadence in seconds.
# Required for the live demo UI.
PERSONA_BATCH_INTERVAL_SECONDS=1.5

# Use the split search/committee manager implementation.
USE_SPLIT_MANAGERS=true

# Persist committee snapshots, reports, and exports alongside search runs.
COMMITTEE_PERSISTENCE_ENABLED=true

# Use Elasticsearch _msearch for batched evaluation in live search mode.
USE_MSEARCH_EVAL=false

# Emit dev-only invariant events when telemetry semantics are violated.
EMIT_INVARIANT_EVENTS=true

# Committee upload size cap in bytes.
MAX_COMMITTEE_UPLOAD_BYTES=8388608

# Optional Elastic-native sink for indexing completed run artifacts back into Elasticsearch/Kibana.
ENABLE_ELASTIC_SINK=false
ELASTIC_SINK_URL=
ELASTIC_SINK_API_KEY=
ELASTIC_SINK_SEARCH_RUNS_PREFIX=elastitune-search-runs
ELASTIC_SINK_SEARCH_EXPERIMENTS_PREFIX=elastitune-search-experiments
ELASTIC_SINK_COMMITTEE_RUNS_PREFIX=elastitune-committee-runs

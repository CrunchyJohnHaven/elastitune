# ElastiTune Backend Environment Variables

# Cost estimate for Elasticsearch storage (USD per GB per month)
COST_PER_GB_MONTH=0.095

# Optional: Default LLM provider settings (used if not overridden per-request)
# Supported providers: openai_compatible, openai, anthropic, disabled
DEFAULT_LLM_PROVIDER=disabled
DEFAULT_LLM_BASE_URL=
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_LLM_API_KEY=

# Optional: Elasticsearch defaults (can also be provided per-request)
ES_URL=
ES_API_KEY=

# Server settings
HOST=0.0.0.0
PORT=8000
